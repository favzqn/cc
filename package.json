{
  "name": "orangehrm-qa-automation",
  "version": "1.0.0",
  "description": "Senior QA Automation Framework for OrangeHRM — Playwright + TypeScript + AI-assisted testing",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --project=smoke --headed",
    "test:regression": "playwright test --grep @regression",
    "test:employee": "playwright test --grep @employee",
    "test:api": "playwright test --project=api",
    "test:visual": "playwright test --project=visual",
    "test:a11y": "playwright test --grep @a11y",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:parallel": "playwright test --workers=4",
    "test:ci": "playwright test --reporter=github,allure-playwright",
    "test:update-snapshots": "playwright test --project=visual --update-snapshots",
    "test:clean": "rm -rf allure-results allure-report reports/html reports/artifacts test-results",
    "test:fresh": "npm run test:clean && playwright test && npm run report:generate",
    "report:open": "allure open allure-report",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "perf:login": "mkdir -p reports/performance && k6 run tests/performance/login.k6.js",
    "perf:employee": "mkdir -p reports/performance && k6 run tests/performance/employee.k6.js",
    "perf:all": "npm run perf:login && npm run perf:employee",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "codegen": "playwright codegen https://opensource-demo.orangehrmlive.com"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "tsc --noEmit --skipLibCheck"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-js-commons": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.6.0"
  }
}
